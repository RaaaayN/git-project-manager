{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-os-agent.local/schemas/project-os-agent.schema.json",
  "title": "Project OS Agent Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "templates_dir": {
      "type": "string",
      "minLength": 1
    },
    "dry_run": {
      "type": "boolean",
      "default": true
    },
    "webhook": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "host": {
          "type": "string",
          "minLength": 1,
          "default": "0.0.0.0"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 8080
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "default": "/webhooks/gitlab"
        },
        "secret_env": {
          "type": "string",
          "minLength": 1,
          "default": "GITLAB_WEBHOOK_SECRET"
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_actions": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_actions": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "phase3": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stale_days": {
          "type": "integer",
          "minimum": 1,
          "default": 14
        },
        "next_steps_default_owner": {
          "type": "string",
          "minLength": 1,
          "default": "@team-core"
        },
        "llm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "provider": {
              "type": "string",
              "enum": [
                "gemini"
              ],
              "default": "gemini"
            },
            "model": {
              "type": "string",
              "minLength": 1,
              "default": "gemini-2.0-flash"
            },
            "api_key_env": {
              "type": "string",
              "minLength": 1,
              "default": "GEMINI_API_KEY"
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 1,
              "maximum": 120,
              "default": 20
            }
          }
        },
        "mcp": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "context_file": {
              "type": "string",
              "minLength": 1,
              "default": ".mcp/context.json"
            }
          }
        }
      }
    },
    "phase4": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "auto_sync_docs": {
          "type": "boolean",
          "default": true
        },
        "mr_title_prefix": {
          "type": "string",
          "minLength": 1,
          "default": "[Agent]"
        },
        "issue_title_prefix": {
          "type": "string",
          "minLength": 1,
          "default": "[Agent][Tracking]"
        },
        "comment_on_source_event": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "phase5": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "log_file": {
              "type": "string",
              "minLength": 1,
              "default": ".project-os-agent/audit.log.jsonl"
            },
            "redact_keys": {
              "type": "array",
              "default": [
                "token",
                "authorization",
                "private_token",
                "api_key",
                "secret"
              ],
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "max_entry_chars": {
              "type": "integer",
              "minimum": 256,
              "default": 2000
            }
          }
        },
        "guardrails": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "safe_write": {
              "type": "boolean",
              "default": true
            },
            "allowed_write_paths": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "blocked_path_prefixes": {
              "type": "array",
              "default": [
                ".git/",
                ".env",
                "secrets/",
                ".mcp/secrets/"
              ],
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "secret_patterns": {
              "type": "array",
              "default": [
                "(?i)glpat-[A-Za-z0-9\\\\-_]{16,}",
                "(?i)AIza[0-9A-Za-z\\\\-_]{35}",
                "(?i)(api[_-]?key|token|secret)\\\\s*[:=]\\\\s*[\\\\\"']?[A-Za-z0-9_\\\\-]{12,}"
              ],
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "max_payload_bytes": {
              "type": "integer",
              "minimum": 1024,
              "default": 524288
            }
          }
        },
        "rate_limit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "state_file": {
              "type": "string",
              "minLength": 1,
              "default": ".project-os-agent/rate-limit.json"
            },
            "window_seconds": {
              "type": "integer",
              "minimum": 1,
              "default": 60
            },
            "max_events": {
              "type": "integer",
              "minimum": 1,
              "default": 30
            }
          }
        },
        "kpi": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "report_dir": {
              "type": "string",
              "minLength": 1,
              "default": ".project-os-agent/reports"
            },
            "report_prefix": {
              "type": "string",
              "minLength": 1,
              "default": "weekly-kpi"
            },
            "rolling_days": {
              "type": "integer",
              "minimum": 1,
              "default": 7
            }
          }
        }
      }
    },
    "gitlab": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "api_url": {
          "type": "string",
          "minLength": 1,
          "default": "https://gitlab.com/api/v4"
        },
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "token_env": {
          "type": "string",
          "minLength": 1,
          "default": "GITLAB_TOKEN"
        },
        "target_branch": {
          "type": "string",
          "minLength": 1,
          "default": "main"
        },
        "branch_prefix": {
          "type": "string",
          "minLength": 1,
          "default": "project-os-agent"
        },
        "labels": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "managed_files": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "template": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "template"
        ]
      }
    },
    "placeholders": {
      "type": "object",
      "default": {},
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "required": [
    "version",
    "templates_dir"
  ]
}
